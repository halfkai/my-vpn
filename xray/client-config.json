{
  "log": {
    "access": "/opt/homebrew/var/log/xray/access.log",
    "error": "/opt/homebrew/var/log/xray/error.log",
    "loglevel": "error"
  },
  "dns": {
    "servers": [
      {
        "address": "https+local://1.1.1.1/dns-query",
        "domains": ["geosite:geolocation-!cn"]
      },
      {
        "address": "https+local://8.8.8.8/dns-query",
        "domains": ["geosite:geolocation-!cn"]
      },
      {
        "address": "https+local://223.5.5.5/dns-query",
        "domains": ["geosite:cn"],
        "expectIPs": ["geoip:cn"]
      },
      {
        "address": "https+local://114.114.114.114/dns-query",
        "domains": ["geosite:cn"]
      },
      {
        "address": "https+local://[2606:4700:4700::1111]/dns-query",
        "domains": ["geosite:geolocation-!cn"]
      },
      {
        "address": "https+local://[2001:4860:4860::8888]/dns-query",
        "domains": ["geosite:geolocation-!cn"]
      },
      "localhost"
    ],
    "queryStrategy": "UseIP"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "protocol": "socks",
      "listen": "127.0.0.1",
      "port": 10800,
      "settings": {
        "udp": true
      }
    },
    {
      "tag": "http-in",
      "protocol": "http",
      "listen": "127.0.0.1",
      "port": 10801
    }
  ],
  "outbounds": [
    {
      "tag": "proxy-cursor",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "<this_should_be_replaced_by_root_domain>",
            "port": 443,
            "users": [
              {
                "id": "<this_should_be_replaced_by_vless_uuid>",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "<this_should_be_replaced_by_root_domain>",
          "fingerprint": "chrome",
          "alpn": ["h2"]
        },
        "xhttpSettings": {
          "path": "<this_should_be_replaced_by_xhttp_path>",
          "mode": "auto"
        }
      }
    },
    {
      "tag": "warp",
      "protocol": "wireguard",
      "settings": {
        "secretKey": "<this_should_be_replaced_by_warp_private_key>",
        "address": ["172.16.0.2/32", "2606:4700:110:818c::2/128"],
        "peers": [
          {
            "publicKey": "<this_should_be_replaced_by_warp_public_key>",
            "endpoint": "engage.cloudflareclient.com:2408"
          }
        ]
      },
      "streamSettings": {
        "sockopt": {
          "dialerProxy": "proxy-cursor"
        }
      }
    },
    {
      "tag": "proxy-vision",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "<this_should_be_replaced_by_root_domain>",
            "port": 443,
            "users": [
              {
                "id": "<this_should_be_replaced_by_vless_uuid>",
                "flow": "xtls-rprx-vision",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "serverName": "<this_should_be_replaced_by_root_domain>",
          "publicKey": "<this_should_be_replaced_by_reality_pub_key>",
          "shortId": "e4c59e0a8bc6f50e"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["socks-in", "http-in"],
        "domain": [
          "domain:chatgpt.com",
          "domain:openai.com",
          "domain:api.openai.com",
          "domain:cdn.openai.com",
          "domain:oaiusercontent.com",
          "domain:*.cursor.sh"
        ],
        "outboundTag": "warp"
      },

      {
        "type": "field",
        "domain": ["geosite:cn", "geosite:private"],
        "outboundTag": "direct"
      },

      {
        "type": "field",
        "domain": ["geosite:geolocation-!cn"],
        "outboundTag": "proxy-vision"
      }
    ]
  }
}
